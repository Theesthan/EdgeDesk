# EdgeDesk Configuration — copy to .env and fill in values

# Ollama settings
OLLAMA_MODEL=phi3.5
OLLAMA_BASE_URL=http://localhost:11434

# Data directory (default: ~/.edgedesk)
DATA_DIR=~/.edgedesk

# Email (optional — for email_reader tool)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# Hotkeys
OVERLAY_HOTKEY=alt+space
